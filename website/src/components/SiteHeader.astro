---
import type { Locale } from "../i18n/types";
import { useTranslations, pageHref } from "../i18n/utils";

interface Props {
  active?: "home" | "math" | "chemistry" | "physics" | "proofs" | "get-started" | "demo";
  lang?: Locale;
}

const { active, lang = "en" } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

// Derive current slug from the request URL so the language switcher points correctly.
const currentPath = Astro.url.pathname;
const relPath = currentPath.startsWith(base) ? currentPath.slice(base.length) : "";
// If already on zh, strip the zh/ prefix (or zh.html for the home page) to get the bare slug.
const isZh = relPath.startsWith("zh/") || relPath === "zh.html";
const slug = isZh ? (relPath === "zh.html" ? "" : relPath.slice(3)) : relPath;

const enHref = pageHref(slug, "en", base);
const zhHref = pageHref(slug, "zh", base);

function navClass(isActive: boolean) {
  return isActive
    ? "font-serif tracking-tight text-orange-700 border-b-2 border-orange-700 pb-1"
    : "font-serif tracking-tight text-zinc-600 hover:text-zinc-900 transition-colors";
}

function langBtnClass(isActive: boolean) {
  return isActive
    ? "px-2 py-1 text-xs font-medium text-orange-700 bg-orange-50 border border-orange-200 rounded"
    : "px-2 py-1 text-xs font-medium text-zinc-500 hover:text-zinc-900 border border-transparent rounded transition-colors";
}
---

<nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-zinc-200 shadow-sm" aria-label="Primary">
  <div class="flex flex-wrap justify-between items-center gap-4 px-6 py-3 max-w-7xl mx-auto">
    <a href={lang === "zh" ? `${base}zh.html` : base} class="text-2xl font-black font-serif text-orange-800">RaTeX</a>
    <div class="hidden lg:flex flex-wrap gap-6 items-center text-sm md:text-base" role="navigation" aria-label="Site sections">
      <a class={navClass(active === "home")} href={active === "home" ? `#features` : pageHref("", lang, base) + "#features"}>{t.nav.features}</a>
      <a class={navClass(active === "demo")} href={pageHref("demo.html", lang, base)}>{t.nav.demo}</a>
      <a class={navClass(active === "math")} href={pageHref("math.html", lang, base)}>{t.nav.math}</a>
      <a class={navClass(active === "chemistry")} href={pageHref("chemistry.html", lang, base)}>{t.nav.chemistry}</a>
      <a class={navClass(active === "physics")} href={pageHref("physics.html", lang, base)}>{t.nav.physics}</a>
      <a class={navClass(active === "proofs")} href={pageHref("proof-trees.html", lang, base)}>{t.nav.proofs}</a>
    </div>
    <div class="flex items-center gap-3">
      <!-- Language switcher: desktop only (mobile uses secondary row) -->
      <div class="hidden lg:flex items-center gap-0.5" aria-label="Language">
        <a href={enHref} class={langBtnClass(lang === "en")} aria-label="English" hreflang="en">{t.nav.langEn}</a>
        <a href={zhHref} class={langBtnClass(lang === "zh")} aria-label="中文" hreflang="zh">{t.nav.langZh}</a>
      </div>
      <a
        href="https://github.com/erweixin/RaTeX"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2 text-on-surface-variant hover:bg-zinc-50 rounded"
        aria-label="RaTeX repository on GitHub"
      >
        <svg width="22" height="22" viewBox="0 0 98 96" xmlns="http://www.w3.org/2000/svg">
          <path
            fill="currentColor"
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.225-22.23-5.378-22.23-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"
          ></path>
        </svg>
      </a>
      <a
        href={pageHref("get-started.html", lang, base)}
        class="bg-primary text-on-primary px-5 py-2 text-xs font-label tracking-widest uppercase hover:opacity-90 transition-opacity"
        >{t.nav.getStarted}</a>
    </div>
  </div>
  <div
    class="lg:hidden border-t border-zinc-100 bg-white/95 px-6 py-2 max-w-7xl mx-auto overflow-x-auto"
    role="navigation"
    aria-label="Quick links"
  >
    <div class="flex gap-4 text-xs font-label uppercase tracking-wider text-zinc-600 whitespace-nowrap pb-0.5">
      <a href={pageHref("math.html", lang, base)} class={navClass(active === "math")}>{t.nav.math}</a>
      <a href={pageHref("chemistry.html", lang, base)} class={navClass(active === "chemistry")}>{t.nav.chemistry}</a>
      <a href={pageHref("physics.html", lang, base)} class={navClass(active === "physics")}>{t.nav.physics}</a>
      <a href={pageHref("proof-trees.html", lang, base)} class={navClass(active === "proofs")}>{t.nav.proofs}</a>
      <a href={pageHref("demo.html", lang, base)} class={navClass(active === "demo")}>{t.nav.demo}</a>
      <a href={active === "home" ? `#features` : pageHref("", lang, base) + "#features"} class={navClass(active === "home")}>{t.nav.features}</a>
      <span class="text-zinc-300" aria-hidden="true">|</span>
      <a href={enHref} class={navClass(lang === "en")} hreflang="en">{t.nav.langEn}</a>
      <a href={zhHref} class={navClass(lang === "zh")} hreflang="zh">{t.nav.langZh}</a>
    </div>
  </div>
</nav>
